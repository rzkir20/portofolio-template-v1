---
import Zap from "@lucide/astro/icons/zap";
---

<main style="view-transition-name: main-content" class="pt-32 pb-24">
  <!-- Page Header -->
  <section class="container mx-auto mb-24 px-6">
    <div
      class="flex flex-col items-end justify-between gap-8 border-b-8 border-black pb-12 lg:flex-row dark:border-white"
    >
      <h1 class="font-display text-[12vw] leading-none lg:text-[10vw]">
        CA-RE-ER <br />
        <span class="bg-black px-4 text-white dark:bg-accent dark:text-black"
          >HISTORY</span
        >
      </h1>
      <div class="text-right lg:w-1/3">
        <p class="text-2xl font-bold tracking-tighter uppercase">
          A timeline of broken rules, <br />
          optimized code, and <br />
          striking interfaces.
        </p>
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="relative container mx-auto px-6">
    <div
      class="timeline-line absolute top-0 bottom-0 left-1/2 z-0 hidden -translate-x-1/2 lg:block"
      aria-hidden="true"
    >
    </div>

    <div class="relative z-10 space-y-16 lg:space-y-32">
      <!-- 01 -->
      <div
        class="group flex flex-col items-center justify-start lg:flex-row lg:items-start"
      >
        <div
          class="w-full rotate-1 bg-accent p-10 text-black transition-transform duration-300 group-hover:rotate-0 lg:w-[45%] brutalist-border brutalist-shadow"
        >
          <div class="mb-6 flex items-start justify-between">
            <span class="font-display text-5xl">01</span>
            <span class="bg-black px-4 py-1 font-bold text-white"
              >2023 - NOW</span
            >
          </div>
          <h2 class="mb-2 font-display text-4xl lg:text-5xl">SENIOR LEAD</h2>
          <p class="mb-6 text-xl font-bold">FUTURESCALE // REMOTE</p>
          <p class="mb-8 text-lg leading-relaxed italic">
            &ldquo;REVOLUTIONIZING CLOUD DASHBOARDS WITH HIGH-CONTRAST DATA
            VISUALIZATION AND ATOMIC DESIGN SYSTEMS.&rdquo;
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="bg-black px-3 py-1 text-sm font-bold text-white"
              >NEXT.JS</span
            >
            <span class="bg-black px-3 py-1 text-sm font-bold text-white"
              >TURBO REPO</span
            >
            <span class="bg-black px-3 py-1 text-sm font-bold text-white"
              >AWS</span
            >
            <span class="bg-black px-3 py-1 text-sm font-bold text-white"
              >D3.JS</span
            >
          </div>
        </div>
      </div>

      <!-- 02 -->
      <div
        class="group flex flex-col items-center justify-end lg:flex-row lg:items-start"
      >
        <div
          class="w-full -rotate-2 bg-white p-10 text-black transition-transform duration-300 group-hover:rotate-0 lg:w-[45%] brutalist-border brutalist-shadow dark:bg-zinc-900 dark:text-white"
        >
          <div class="mb-6 flex items-start justify-between">
            <span class="font-display text-5xl">02</span>
            <span class="bg-accent px-4 py-1 font-bold text-black"
              >2021 - 2023</span
            >
          </div>
          <h2 class="mb-2 font-display text-4xl lg:text-5xl">FULL STACK</h2>
          <p class="mb-6 text-xl font-bold">NEOCORE SYSTEMS // BERLIN</p>
          <p class="mb-8 text-lg leading-relaxed">
            DEVELOPED REAL-TIME TRADING ENGINES AND ROBUST GRAPHQL APIS. SCALED
            TRAFFIC FROM 10K TO 1M MAU WITHOUT DOWNTIME.
          </p>
          <div class="flex flex-wrap gap-2">
            <span
              class="border-2 border-black px-3 py-1 text-sm font-bold dark:border-white"
              >TYPESCRIPT</span
            >
            <span
              class="border-2 border-black px-3 py-1 text-sm font-bold dark:border-white"
              >RUST</span
            >
            <span
              class="border-2 border-black px-3 py-1 text-sm font-bold dark:border-white"
              >POSTGRES</span
            >
            <span
              class="border-2 border-black px-3 py-1 text-sm font-bold dark:border-white"
              >REDIS</span
            >
          </div>
        </div>
      </div>

      <!-- 03 -->
      <div
        class="group flex flex-col items-center justify-start lg:flex-row lg:items-start"
      >
        <div
          class="w-full rotate-2 bg-black p-10 text-white transition-transform duration-300 group-hover:rotate-0 lg:w-[45%] brutalist-border brutalist-shadow dark:bg-white dark:text-black"
        >
          <div class="mb-6 flex items-start justify-between">
            <span class="font-display text-5xl">03</span>
            <span class="bg-accent px-4 py-1 font-bold text-black"
              >2019 - 2021</span
            >
          </div>
          <h2 class="mb-2 font-display text-4xl lg:text-5xl">UX ENGINEER</h2>
          <p class="mb-6 text-xl font-bold">PIXELPUSH STUDIO // JKT</p>
          <p class="mb-8 text-lg leading-relaxed">
            WHERE DESIGN MEETS CODE. BUILT HIGH-FIDELITY PROTOTYPES THAT BECAME
            INDUSTRY STANDARDS IN THE FINTECH SPACE.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="bg-accent px-3 py-1 text-sm font-bold text-black"
              >VUE 3</span
            >
            <span class="bg-accent px-3 py-1 text-sm font-bold text-black"
              >FRAMER MOTION</span
            >
            <span class="bg-accent px-3 py-1 text-sm font-bold text-black"
              >FIGMA</span
            >
          </div>
        </div>
      </div>

      <!-- 04 -->
      <div
        class="group flex flex-col items-center justify-end lg:flex-row lg:items-start"
      >
        <div
          class="w-full -rotate-1 bg-accent p-10 text-black transition-transform duration-300 group-hover:rotate-0 lg:w-[45%] brutalist-border brutalist-shadow"
        >
          <div class="mb-6 flex items-start justify-between">
            <span class="font-display text-5xl">04</span>
            <span class="bg-black px-4 py-1 font-bold text-white"
              >2018 - 2019</span
            >
          </div>
          <h2 class="mb-2 font-display text-4xl lg:text-5xl">JUNIOR DEV</h2>
          <p class="mb-6 text-xl font-bold">STARTUP HUB // JKT</p>
          <p class="mb-8 text-lg leading-relaxed">
            LEARNED THE ROPES. BUILT 50+ LANDING PAGES AND MASTERED THE ART OF
            THE CLEAN GIT COMMIT.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="bg-black px-3 py-1 text-sm font-bold text-white"
              >JAVASCRIPT</span
            >
            <span class="bg-black px-3 py-1 text-sm font-bold text-white"
              >PHP</span
            >
            <span class="bg-black px-3 py-1 text-sm font-bold text-white"
              >JQUERY</span
            >
          </div>
        </div>
      </div>

      <!-- 05 -->
      <div
        class="group flex flex-col items-center justify-start lg:flex-row lg:items-start"
      >
        <div
          class="w-full rotate-3 bg-white p-10 text-black transition-transform duration-300 group-hover:rotate-0 lg:w-[45%] brutalist-border brutalist-shadow dark:bg-zinc-900 dark:text-white"
        >
          <div class="mb-6 flex items-start justify-between">
            <span class="font-display text-5xl">05</span>
            <span class="bg-accent px-4 py-1 font-bold text-black"
              >2017 - 2018</span
            >
          </div>
          <h2 class="mb-2 font-display text-4xl lg:text-5xl">FREELANCE</h2>
          <p class="mb-6 text-xl font-bold">VARIOUS CLIENTS // GLOBAL</p>
          <p class="mb-8 text-lg leading-relaxed">
            THE HUSTLE. DESIGNED LOGOS, CODED WEBSITES, AND MANAGED CLIENT
            EXPECTATIONS ACROSS 5 TIMEZONES.
          </p>
          <div class="flex flex-wrap gap-2">
            <span
              class="border-2 border-black px-3 py-1 text-sm font-bold dark:border-white"
              >WP</span
            >
            <span
              class="border-2 border-black px-3 py-1 text-sm font-bold dark:border-white"
              >SHOPIFY</span
            >
            <span
              class="border-2 border-black px-3 py-1 text-sm font-bold dark:border-white"
              >UI/UX</span
            >
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="container mx-auto mt-32 px-6">
    <div
      class="relative flex flex-col items-center justify-between gap-12 overflow-hidden bg-black p-16 text-white brutalist-border brutalist-shadow lg:flex-row"
    >
      <div class="relative z-10">
        <h2 class="mb-6 font-display text-6xl lg:text-8xl">WANT MORE?</h2>
        <p class="max-w-xl text-2xl font-bold">
          HIRE ME TO BREAK YOUR COMPETITION'S GRIDS AND BUILD SYSTEMS THAT
          ACTUALLY WORK.
        </p>
      </div>
      <a
        href="/contact"
        id="cta-exp-contact"
        class="relative z-10 bg-accent px-12 py-8 font-display text-4xl text-black transition-all brutalist-border hover:-translate-y-2 hover:bg-white"
      >
        LET'S TALK
      </a>
      <div
        class="pointer-events-none absolute -right-20 -bottom-20 text-white opacity-10"
        aria-hidden="true"
      >
        <Zap class="size-[400px] stroke-1" />
      </div>
    </div>
  </section>
</main>
