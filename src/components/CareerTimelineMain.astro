---
import Zap from "@lucide/astro/icons/zap";

import data from "../assets/data.json";

const career = data.career as unknown as CareerEntry[];

const cardToneClass: Record<CareerTone, string> = {
  accent: "bg-accent text-black",
  surface: "bg-white text-black dark:bg-zinc-900 dark:text-white",
  inverted: "bg-black text-white dark:bg-white dark:text-black",
};

const periodClass: Record<PeriodStyle, string> = {
  onDark: "bg-black px-4 py-1 font-bold text-white",
  onAccent: "bg-accent px-4 py-1 font-bold text-black",
};

const tagClass: Record<TagStyle, string> = {
  pillDark: "bg-black px-3 py-1 text-sm font-bold text-white",
  outline:
    "border-2 border-black px-3 py-1 text-sm font-bold dark:border-white",
  pillAccent: "bg-accent px-3 py-1 text-sm font-bold text-black",
};
---

<main style="view-transition-name: main-content" class="pt-32 pb-24">
  <!-- Page Header -->
  <section class="container mx-auto mb-24 px-6">
    <div
      class="flex flex-col items-end justify-between gap-8 border-b-8 border-black pb-12 lg:flex-row dark:border-white"
    >
      <h1 class="font-display text-[12vw] leading-none lg:text-[10vw]">
        CA-RE-ER <br />
        <span class="bg-black px-4 text-white dark:bg-accent dark:text-black"
          >HISTORY</span
        >
      </h1>
      <div class="text-right lg:w-1/3">
        <p class="text-2xl font-bold tracking-tighter uppercase">
          A timeline of broken rules, <br />
          optimized code, and <br />
          striking interfaces.
        </p>
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="relative container mx-auto px-6">
    <div
      class="timeline-line absolute top-0 bottom-0 left-1/2 z-0 hidden -translate-x-1/2 lg:block"
      aria-hidden="true"
    >
    </div>

    <div class="relative z-10 space-y-16 lg:space-y-32">
      {
        career.map((item, i) => {
          const num = String(i + 1).padStart(2, "0");
          const rowJustify = item.rowEnd ? "justify-end" : "justify-start";
          return (
            <div
              class:list={[
                "group flex flex-col items-center lg:flex-row lg:items-start",
                rowJustify,
              ]}
            >
              <div
                class:list={[
                  "w-full p-10 transition-transform duration-300 group-hover:rotate-0 lg:w-[45%] brutalist-border brutalist-shadow",
                  item.rotate,
                  cardToneClass[item.tone],
                ]}
              >
                <div class="mb-6 flex items-start justify-between">
                  <span class="font-display text-5xl">{num}</span>
                  <span class={periodClass[item.periodStyle]}>
                    {item.period}
                  </span>
                </div>
                <h2 class="mb-2 font-display text-4xl lg:text-5xl">
                  {item.title}
                </h2>
                <p class="mb-6 text-xl font-bold">{item.company}</p>
                {item.quote ? (
                  <p class="mb-8 text-lg leading-relaxed italic">
                    &ldquo;{item.description}&rdquo;
                  </p>
                ) : (
                  <p class="mb-8 text-lg leading-relaxed">{item.description}</p>
                )}
                <div class="flex flex-wrap gap-2">
                  {item.skills.map((skill) => (
                    <span class={tagClass[item.tagStyle]}>{skill}</span>
                  ))}
                </div>
              </div>
            </div>
          );
        })
      }
    </div>
  </section>

  <!-- CTA -->
  <section class="container mx-auto mt-32 px-6">
    <div
      class="relative flex flex-col items-center justify-between gap-12 overflow-hidden bg-black p-16 text-white brutalist-border brutalist-shadow lg:flex-row"
    >
      <div class="relative z-10">
        <h2 class="mb-6 font-display text-6xl lg:text-8xl">WANT MORE?</h2>
        <p class="max-w-xl text-2xl font-bold">
          HIRE ME TO BREAK YOUR COMPETITION'S GRIDS AND BUILD SYSTEMS THAT
          ACTUALLY WORK.
        </p>
      </div>
      <a
        href="/contact"
        id="cta-exp-contact"
        class="relative z-10 bg-accent px-12 py-8 font-display text-4xl text-black transition-all brutalist-border hover:-translate-y-2 hover:bg-white"
      >
        LET'S TALK
      </a>
      <div
        class="pointer-events-none absolute -right-20 -bottom-20 text-white opacity-10"
        aria-hidden="true"
      >
        <Zap class="size-[400px] stroke-1" />
      </div>
    </div>
  </section>
</main>
