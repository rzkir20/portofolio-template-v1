---
const { variant, title, description } = Astro.props;

const iconBox: Record<typeof variant, string> = {
  yellow: "bg-yellow-100 text-yellow-600 dark:bg-yellow-900/30",
  blue: "bg-blue-100 text-blue-600 dark:bg-blue-900/30",
  purple: "bg-purple-100 text-purple-600 dark:bg-purple-900/30",
  neutral: "bg-zinc-200 text-zinc-800 dark:bg-zinc-800 dark:text-zinc-200",
};
---

<div
  class="group bg-white p-8 transition-transform duration-200 hover:-translate-y-1 dark:bg-zinc-950 brutalist-border brutalist-shadow-sm"
  style="transition-timing-function: cubic-bezier(0.175, 0.885, 0.32, 1.275);"
>
  <div
    class={`mb-6 flex size-12 items-center justify-center [&_svg]:size-6 ${iconBox[variant]}`}
    aria-hidden="true"
  >
    <slot />
  </div>
  <h3 class="mb-2 font-display text-lg font-bold">{title}</h3>
  <p class="text-sm text-zinc-600 dark:text-zinc-400">{description}</p>
</div>
