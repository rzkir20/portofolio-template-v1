---
import Mail from "@lucide/astro/icons/mail";
import MapPin from "@lucide/astro/icons/map-pin";
import Send from "@lucide/astro/icons/send";
import LoaderCircle from "@lucide/astro/icons/loader-circle";
import FileText from "@lucide/astro/icons/file-text";
import Braces from "@lucide/astro/icons/braces";
import Component from "@lucide/astro/icons/component";
import Wind from "@lucide/astro/icons/wind";
import Server from "@lucide/astro/icons/server";
import Container from "@lucide/astro/icons/container";
import PenTool from "@lucide/astro/icons/pen-tool";
import GitBranch from "@lucide/astro/icons/git-branch";
import Link2 from "@lucide/astro/icons/link-2";
import Hash from "@lucide/astro/icons/hash";
import data from "../assets/data.json";
import resumePdf from "../assets/Resume-Rizki-Ramadhan.pdf";

type CvEntryVariant = "dark" | "accent";

const contact = data.contact;
const cvEntryBlock: Record<CvEntryVariant, string> = {
	dark: "border-l-8 border-black pl-6 dark:border-white",
	accent: "border-l-8 border-accent pl-6",
};
const cvEntryPeriod: Record<CvEntryVariant, string> = {
	dark: "mb-2 inline-block bg-black px-2 font-bold text-accent",
	accent: "mb-2 inline-block bg-accent px-2 font-bold text-black",
};

const skillIconMap = {
	braces: Braces,
	component: Component,
	wind: Wind,
	server: Server,
	container: Container,
	"pen-tool": PenTool,
} as const;

type SkillIconKey = keyof typeof skillIconMap;

const socialIconMap = {
	"git-branch": GitBranch,
	"link-2": Link2,
	hash: Hash,
} as const;

type SocialIconKey = keyof typeof socialIconMap;

/** JSON `row1` fields use these input types; narrows for JSX `input[type]`. */
type ContactFormInputType = "text" | "email";
---

<main style="view-transition-name: main-content" class="pt-32 pb-24">
	<div class="container mx-auto px-6">
		<header class="mb-20">
			<h1 class="mb-4 font-display text-[12vw] leading-none lg:text-[10vw]">
				{contact.header.titleLine} <br />
				<span class="bg-black px-4 text-white dark:bg-white dark:text-black"
					>{contact.header.titleHighlight}</span
				>
			</h1>
			<div class="-rotate-2 inline-block bg-accent p-4 font-bold text-2xl text-black brutalist-border">
				{contact.header.badge}
			</div>
		</header>

		<div class="grid grid-cols-1 items-start gap-12 lg:grid-cols-12">
			<!-- Contact form + channels -->
			<div class="space-y-12 lg:col-span-5">
				<div class="bg-white p-8 brutalist-border brutalist-shadow dark:bg-zinc-900">
					<h2 class="mb-8 border-b-4 border-black pb-4 font-display text-4xl dark:border-white">
						{contact.form.sectionTitle}
					</h2>

					<form
						id="contact-page-form"
						class="space-y-6"
						data-label-submit={contact.form.submitLabel}
						data-label-submitting={contact.form.submittingLabel}
						data-label-success={contact.form.successLabel}
					>
						<div class="grid grid-cols-1 gap-6 md:grid-cols-2">
							{
								contact.form.row1.map((field) => (
									<div class="space-y-2">
										<label class="font-display text-sm font-semibold">{field.label}</label>
										<input
											name={field.name}
											type={field.type as ContactFormInputType}
											placeholder={field.placeholder}
											required
											class="w-full border-4 border-black bg-transparent px-5 py-4 transition-all outline-none focus:bg-accent focus:text-black dark:border-white"
										/>
									</div>
								))
							}
						</div>
						<div class="space-y-2">
							<label class="font-display text-sm font-semibold">{contact.form.message.label}</label>
							<textarea
								name={contact.form.message.name}
								rows={contact.form.message.rows}
								placeholder={contact.form.message.placeholder}
								required
								class="w-full resize-none border-4 border-black bg-transparent px-5 py-4 transition-all outline-none focus:bg-accent focus:text-black dark:border-white"
							></textarea>
						</div>
						<button
							type="submit"
							id="btn-contact-page-submit"
							class="flex w-full items-center justify-center gap-2 bg-black py-4 font-bold text-white transition-all brutalist-border hover:bg-accent hover:text-black disabled:cursor-not-allowed disabled:opacity-70 dark:bg-white dark:text-black dark:hover:bg-accent dark:hover:text-black"
						>
							<span id="btn-contact-page-label">{contact.form.submitLabel}</span>
							<Send id="btn-contact-page-icon-send" class="size-5 stroke-2" aria-hidden="true" />
							<LoaderCircle
								id="btn-contact-page-icon-loader"
								class="hidden size-5 animate-spin stroke-2"
								aria-hidden="true"
							/>
						</button>
					</form>
				</div>

				<div class="rotate-1 bg-black p-8 text-white brutalist-border brutalist-shadow">
					<h3 class="mb-6 font-display text-3xl text-accent">{contact.channels.title}</h3>
					<div class="space-y-4 font-bold">
						<p class="flex items-center gap-4 text-xl">
							<Mail class="size-8 shrink-0 stroke-[1.5]" aria-hidden="true" />
							{contact.channels.email}
						</p>
						<p class="flex items-center gap-4 text-xl">
							<MapPin class="size-8 shrink-0 stroke-[1.5]" aria-hidden="true" />
							{contact.channels.location}
						</p>
						<div class="flex gap-6 pt-4 text-3xl">
							{
								contact.channels.social.map((s) => {
									const Icon = socialIconMap[s.icon as SocialIconKey];
									return (
										<a href={s.href} id={s.id} class="hover:text-accent" aria-label={s.ariaLabel}>
											<Icon class="size-10 stroke-[1.5]" />
										</a>
									);
								})
							}
						</div>
					</div>
				</div>
			</div>

			<!-- CV column -->
			<div id="cv" class="space-y-12 lg:col-span-7">
				<div class="bg-zinc-100 p-8 brutalist-border brutalist-shadow dark:bg-zinc-800">
					<h2 class="mb-8 flex items-center justify-between font-display text-4xl">
						{contact.cv.title}
						<FileText class="size-10 stroke-[1.5] text-accent" aria-hidden="true" />
					</h2>

					<div class="space-y-8">
						{
							contact.cv.entries.map((entry) => {
								const v = entry.variant as CvEntryVariant;
								return (
									<div class={cvEntryBlock[v]}>
										<p class={cvEntryPeriod[v]}>{entry.period}</p>
										<h3 class="font-display text-2xl">{entry.title}</h3>
										<p class="font-bold opacity-70">{entry.company}</p>
									</div>
								);
							})
						}
					</div>
				</div>

				<div class="grid grid-cols-2 gap-6 md:grid-cols-3">
					{
						contact.cv.skills.map((skill) => {
							const Icon = skillIconMap[skill.icon as SkillIconKey];
							return (
								<div class={skill.tileClass}>
									<Icon class="mb-2 size-14 stroke-[1.25]" aria-hidden="true" />
									<span class="font-display text-sm">{skill.label}</span>
								</div>
							);
						})
					}
				</div>

				<div class="pt-8">
					<a
						href={resumePdf}
						download="Resume-Rizki-Ramadhan.pdf"
						id={contact.cv.download.id}
						class="glitch block w-full bg-accent py-10 text-center font-display text-5xl text-black transition-all brutalist-border brutalist-shadow hover:translate-x-2 hover:translate-y-2 hover:shadow-none"
					>
						{contact.cv.download.label}
					</a>
					<p
						class="mt-6 text-center font-bold tracking-widest text-zinc-500 uppercase dark:text-zinc-400"
					>
						{contact.cv.download.subtext}
					</p>
				</div>

				<div class="relative -rotate-1 bg-black px-8 py-12 text-white brutalist-border brutalist-shadow">
					<h3 class="mb-6 font-display text-3xl">{contact.cv.education.title}</h3>
					<ul class="space-y-6">
						{
							contact.cv.education.items.map((item) => (
								<li class="flex gap-4">
									<span class="h-fit bg-accent px-2 font-bold text-black">{item.year}</span>
									<div>
										<p class="font-display text-xl">{item.degree}</p>
										<p class="opacity-70">{item.school}</p>
									</div>
								</li>
							))
						}
					</ul>
				</div>
			</div>
		</div>
	</div>
</main>

<script is:inline>
	const form = document.getElementById("contact-page-form");
	const btn = document.getElementById("btn-contact-page-submit");
	const label = document.getElementById("btn-contact-page-label");
	const iconSend = document.getElementById("btn-contact-page-icon-send");
	const iconLoader = document.getElementById("btn-contact-page-icon-loader");

	form?.addEventListener("submit", (e) => {
		e.preventDefault();
		if (!btn || !label || !iconSend || !iconLoader || !form) return;

		const original =
			form.dataset.labelSubmit ?? label.textContent ?? "";
		const sending = form.dataset.labelSubmitting ?? "SENDING...";
		const success = form.dataset.labelSuccess ?? "MESSAGE SENT //";

		btn.disabled = true;
		label.textContent = sending;
		iconSend.classList.add("hidden");
		iconLoader.classList.remove("hidden");

		setTimeout(() => {
			label.textContent = success;
			iconLoader.classList.add("hidden");
			iconSend.classList.remove("hidden");
			form.reset();

			setTimeout(() => {
				label.textContent = original;
				btn.disabled = false;
			}, 2500);
		}, 1200);
	});
</script>
