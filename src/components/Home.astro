---
import Trophy from "@lucide/astro/icons/trophy";
import ShieldCheck from "@lucide/astro/icons/shield-check";
import Users from "@lucide/astro/icons/users";
import MessageSquare from "@lucide/astro/icons/message-square";
import Gamepad2 from "@lucide/astro/icons/gamepad-2";
import data from "../assets/data.json";
import profileImage from "../assets/me.jpeg";

const home = data.home;

const highlightIconMap = {
  trophy: Trophy,
  "shield-check": ShieldCheck,
  users: Users,
} as const;

type HighlightIconKey = keyof typeof highlightIconMap;

const featureIconMap = {
  "message-square": MessageSquare,
  "gamepad-2": Gamepad2,
} as const;

type FeatureIconKey = keyof typeof featureIconMap;
---

<main class="overflow-x-hidden">
  <!-- Hero -->
  <section
    id="home"
    class="relative flex min-h-screen items-center overflow-hidden pt-20 pb-8 sm:pt-24 sm:pb-12"
  >
    <div
      class="pointer-events-none absolute top-1/4 -left-16 max-w-[120vw] -rotate-12 select-none font-display text-[clamp(3.5rem,20vw,14rem)] leading-none whitespace-nowrap opacity-5 sm:-left-20 dark:opacity-10"
    >
      {home.hero.backgroundWord}
    </div>

    <div class="relative z-10 container mx-auto px-4 sm:px-6">
      <div class="flex flex-col items-start gap-8 lg:flex-row lg:items-center">
        <div class="min-w-0 w-full lg:w-2/3">
          <div
            class="mb-6 sm:mb-8 inline-block max-w-full bg-accent px-3 py-1 text-base font-bold text-black brutalist-border sm:px-4 sm:text-xl"
          >
            {home.hero.badge}
          </div>
          <h1
            class="mb-4 max-w-full wrap-break-word font-display text-[clamp(2.25rem,9.5vw+0.5rem,7.5rem)] leading-[0.92]"
          >
            {home.hero.title.before}
            <br />
            <span
              class="box-decoration-clone bg-black px-2 py-1 text-white sm:px-4 sm:py-0 dark:bg-white dark:text-black"
              >{home.hero.title.highlight}</span
            ><br />
            {home.hero.title.after}
          </h1>
          <p
            class="mt-6 mb-8 max-w-2xl border-l-4 border-black pl-4 text-lg font-bold sm:mt-8 sm:mb-12 sm:border-l-8 sm:pl-6 sm:text-2xl lg:text-3xl dark:border-white"
          >
            {
              home.hero.taglines.map((line, i) => (
                <>
                  {i > 0 && <br />}
                  {line}
                </>
              ))
            }
          </p>
          <div
            class="flex w-full flex-col gap-4 sm:flex-row sm:flex-wrap sm:gap-6"
          >
            {
              home.hero.ctas.map((cta) => (
                <a href={cta.href} id={cta.id} class={cta.class}>
                  {cta.label}
                </a>
              ))
            }
          </div>
        </div>

        <div
          class="relative mt-10 w-full shrink-0 pb-14 sm:pb-16 lg:mt-0 lg:w-1/3 lg:pb-0"
        >
          <div
            class="relative mx-auto aspect-3/4 max-w-md overflow-hidden bg-zinc-200 grayscale transition-all brutalist-border brutalist-shadow hover:grayscale-0 sm:max-w-none lg:mx-0"
          >
            <img
              src={profileImage.src}
              alt={home.hero.profile.alt}
              class="h-full w-full object-cover"
            />
            <div
              class="pointer-events-none absolute inset-0 border-20 border-black/20"
            >
            </div>
          </div>
          <div
            class="absolute right-2 bottom-2 rotate-6 border-4 border-black bg-black p-3 font-display text-2xl text-white brutalist-border brutalist-shadow-sm sm:-right-6 sm:-bottom-6 sm:p-5 sm:text-3xl md:-right-8 md:-bottom-8 md:p-6 md:text-4xl dark:border-white dark:bg-white dark:text-black"
          >
            {home.hero.profile.nameBadge}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Marquee -->
  <div
    class="overflow-hidden border-y-8 border-black bg-black py-6 whitespace-nowrap text-white dark:border-white dark:bg-accent dark:text-black"
  >
    <div class="animate-marquee flex gap-12 font-display text-4xl">
      <span>{home.marquee.text}</span>
      <span>{home.marquee.text}</span>
    </div>
  </div>

  <!-- Experience -->
  <section
    id="experience"
    class="overflow-hidden bg-zinc-100 py-12 sm:py-16 lg:py-24 dark:bg-zinc-900"
  >
    <div class="container mx-auto px-4 sm:px-6">
      <h2
        class="diagonal-text mb-8 font-display text-4xl sm:mb-12 sm:text-6xl md:mb-16 md:text-7xl lg:text-9xl"
      >
        {home.experience.title}
      </h2>

      <div
        class="grid grid-cols-1 gap-0 border-4 border-black sm:border-8 lg:grid-cols-2 dark:border-white"
      >
        {
          home.experience.items.map((item) => (
            <div class={item.cardClass}>
              <div class="mb-4 flex flex-wrap gap-2 sm:mb-6 sm:items-start sm:justify-between">
                <span class="font-display text-3xl sm:text-4xl">
                  {item.index}
                </span>
                <span class={item.periodBadgeClass}>{item.period}</span>
              </div>
              <h3 class="mb-3 wrap-break-word font-display text-3xl sm:mb-4 sm:text-4xl md:text-5xl">
                {item.role}
              </h3>
              <p class="mb-6 text-lg font-bold sm:mb-8 sm:text-xl">
                {item.company}
              </p>
              <p class="text-base leading-relaxed sm:text-lg">
                {item.description}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Achievements -->
  <section id="achievements" class="py-12 sm:py-16 lg:py-24">
    <div class="container mx-auto px-4 sm:px-6">
      <div
        class="grid grid-cols-1 gap-6 md:grid-cols-2 md:gap-8 xl:grid-cols-3"
      >
        {
          home.highlights.map((card) => {
            const Icon = highlightIconMap[card.icon as HighlightIconKey];
            return (
              <div class={`min-w-0 ${card.cardClass}`}>
                <Icon class={card.iconClass} aria-hidden="true" />
                <h3 class="mb-3 wrap-break-word font-display text-2xl sm:mb-4 sm:text-3xl md:text-4xl">
                  {card.title}
                </h3>
                <p class="text-base opacity-80 sm:text-lg">
                  {card.description}
                </p>
              </div>
            );
          })
        }
      </div>
    </div>
  </section>

  <!-- Guestbook & Arcade -->
  <section class="bg-black py-12 sm:py-16 lg:py-24">
    <div
      class="container mx-auto grid grid-cols-1 gap-8 px-4 sm:gap-10 sm:px-6 md:grid-cols-2 md:gap-12"
    >
      {
        home.featurePanels.map((panel) => {
          const Icon = featureIconMap[panel.icon as FeatureIconKey];
          return (
            <div id={panel.sectionId} class={panel.wrapperClass}>
              <div class="relative z-10 min-w-0">
                <h3 class="mb-4 wrap-break-word font-display text-3xl sm:mb-6 sm:text-5xl md:text-6xl">
                  {panel.title}
                </h3>
                <p class="mb-6 text-lg font-bold sm:mb-10 sm:text-xl">
                  {panel.description}
                </p>
                <a
                  href={panel.href}
                  id={panel.buttonId}
                  class={panel.buttonClass}
                >
                  {panel.buttonLabel}
                </a>
              </div>
              <Icon class={panel.iconClass} aria-hidden="true" />
            </div>
          );
        })
      }
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="relative py-12 sm:py-16 lg:py-24">
    <div class="container mx-auto max-w-4xl px-4 sm:px-6">
      <div class="mb-8 text-center sm:mb-12 lg:mb-16">
        <h2
          class="mb-3 font-display text-[clamp(2.5rem,12vw,5.5rem)] leading-[0.95] sm:mb-4"
        >
          {home.contact.title}
        </h2>
        <p
          class="px-2 text-base font-bold tracking-wider uppercase sm:text-xl md:text-2xl md:tracking-widest"
        >
          {home.contact.subtitle}
        </p>
      </div>

      <form
        id={home.contact.formId}
        data-home-contact-form
        class="grid grid-cols-1 gap-6 bg-white p-4 brutalist-border brutalist-shadow sm:gap-8 sm:p-8 md:p-12 dark:bg-zinc-900"
      >
        <div class="grid grid-cols-1 gap-6 sm:gap-8 md:grid-cols-2">
          <div class="space-y-2">
            <label class="font-display text-lg sm:text-xl"
              >{home.contact.name.label}</label
            >
            <input
              type="text"
              name={home.contact.name.name}
              placeholder={home.contact.name.placeholder}
              class="w-full min-w-0 border-4 border-black bg-transparent p-4 transition-all outline-none focus:bg-accent focus:text-black sm:p-6 dark:border-white"
            />
          </div>
          <div class="space-y-2">
            <label class="font-display text-lg sm:text-xl"
              >{home.contact.email.label}</label
            >
            <input
              type="email"
              name={home.contact.email.name}
              placeholder={home.contact.email.placeholder}
              class="w-full min-w-0 border-4 border-black bg-transparent p-4 transition-all outline-none focus:bg-accent focus:text-black sm:p-6 dark:border-white"
            />
          </div>
        </div>
        <div class="space-y-2">
          <label class="font-display text-lg sm:text-xl"
            >{home.contact.message.label}</label
          >
          <textarea
            name={home.contact.message.name}
            rows={home.contact.message.rows}
            placeholder={home.contact.message.placeholder}
            class="w-full min-w-0 resize-none border-4 border-black bg-transparent p-4 transition-all outline-none focus:bg-accent focus:text-black sm:p-6 dark:border-white"
          ></textarea>
        </div>
        <button
          type="submit"
          id={home.contact.submitButtonId}
          class="w-full border-4 border-black bg-black py-5 font-display text-2xl text-white transition-all hover:bg-accent hover:text-black sm:py-8 sm:text-4xl dark:border-white dark:bg-white dark:text-black dark:hover:bg-accent dark:hover:text-black"
        >
          {home.contact.submitLabel}
        </button>
      </form>
    </div>
  </section>
</main>

<script is:inline>
  document
    .querySelector("[data-home-contact-form]")
    ?.addEventListener("submit", (e) => {
      e.preventDefault();
    });
</script>
