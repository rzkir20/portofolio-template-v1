---
import Flame from "@lucide/astro/icons/flame";
import data from "../assets/data.json";

const gb = data.guestbook;
---

<main class="pt-32 pb-24">
	<section class="container mx-auto mb-24 px-6">
		<div class="flex flex-col items-end gap-4 lg:flex-row">
			<h1 class="mb-0 font-display text-[10vw] leading-none">
				{gb.header.titleLine} <br />
				<span class="bg-accent px-4 text-black">{gb.header.titleHighlight}</span>
			</h1>
			<div
				class="mb-4 bg-black px-6 py-2 font-bold text-xl text-white brutalist-border lg:mb-8 dark:bg-white dark:text-black"
			>
				{gb.header.version}
			</div>
		</div>
		<p
			class="mt-8 max-w-2xl border-l-8 border-black pl-6 text-2xl font-bold dark:border-white"
		>
			{gb.intro.lines.map((line, i) => (
				<>
					{i > 0 && <br />}
					{line}
				</>
			))}
		</p>
	</section>

	<div class="container mx-auto grid grid-cols-1 gap-12 px-6 lg:grid-cols-12">
		<aside class="lg:col-span-5">
			<div class="sticky top-32">
				<div class="bg-white p-8 brutalist-border brutalist-shadow dark:bg-zinc-900">
					<h2 class="mb-8 font-display text-4xl">{gb.form.title}</h2>
					<form
						id="guestbook-form"
						class="space-y-6"
						data-label-submit={gb.form.submitLabel}
						data-label-submitting={gb.form.submittingLabel}
						data-label-success={gb.form.successLabel}
					>
						<div class="space-y-2">
							<label class="font-display text-lg">{gb.form.name.label}</label>
							<input
								type="text"
								name={gb.form.name.name}
								placeholder={gb.form.name.placeholder}
								required
								class="w-full border-4 border-black bg-transparent p-6 transition-all outline-none placeholder:opacity-30 focus:bg-accent focus:text-black dark:border-white"
							/>
						</div>
						<div class="space-y-2">
							<label class="font-display text-lg">{gb.form.email.label}</label>
							<input
								type="email"
								name={gb.form.email.name}
								placeholder={gb.form.email.placeholder}
								class="w-full border-4 border-black bg-transparent p-6 transition-all outline-none placeholder:opacity-30 focus:bg-accent focus:text-black dark:border-white"
							/>
						</div>
						<div class="space-y-2">
							<label class="font-display text-lg">{gb.form.message.label}</label>
							<textarea
								name={gb.form.message.name}
								rows={gb.form.message.rows}
								placeholder={gb.form.message.placeholder}
								required
								class="w-full resize-none border-4 border-black bg-transparent p-6 transition-all outline-none placeholder:opacity-30 focus:bg-accent focus:text-black dark:border-white"
							></textarea>
						</div>
						<button
							type="submit"
							id="btn-submit-guestbook"
							class="glitch w-full bg-black py-6 font-display text-3xl text-white transition-all brutalist-border hover:bg-accent hover:text-black dark:bg-white dark:text-black dark:hover:bg-accent dark:hover:text-black"
						>
							{gb.form.submitLabel}
						</button>
					</form>
				</div>

				<div class="mt-8 rotate-2 bg-accent p-6 text-black brutalist-border">
					<p class="text-lg font-bold tracking-tighter uppercase">
						{gb.note}
					</p>
				</div>
			</div>
		</aside>

		<section class="lg:col-span-7">
			<div class="mb-12 flex items-center justify-between">
				<h2 class="font-display text-5xl">{gb.list.title}</h2>
				<div class="font-bold">{gb.list.entriesBadge}</div>
			</div>

			<div id="message-list" class="grid grid-cols-1 gap-12">
				{
					gb.entries.map((entry) => (
						<div class={entry.cardClass}>
							<div class="mb-6 flex items-start justify-between">
								<div class={entry.badgeClass}>{entry.id}</div>
								<span class="text-sm font-bold opacity-60">{entry.datetime}</span>
							</div>
							<h3 class="mb-4 font-display text-3xl">{entry.author}</h3>
							<p class={entry.messageClass}>{entry.message}</p>
							{entry.showFlame ? (
								<div class="absolute -right-4 -bottom-4 hidden bg-white p-2 brutalist-border group-hover:block dark:bg-zinc-800">
									<Flame class="size-8 stroke-[1.5] text-red-500" aria-hidden="true" />
								</div>
							) : null}
						</div>
					))
				}
			</div>

			<button
				type="button"
				id="btn-load-more"
				class="mt-16 w-full bg-black p-8 font-display text-2xl text-white transition-all brutalist-border hover:bg-accent hover:text-black dark:bg-white dark:text-black dark:hover:bg-accent dark:hover:text-black"
			>
				{gb.list.loadMoreLabel}
			</button>
		</section>
	</div>
</main>

<script is:inline>
	const form = document.getElementById("guestbook-form");
	const btn = document.getElementById("btn-submit-guestbook");
	form?.addEventListener("submit", (e) => {
		e.preventDefault();
		if (!btn || !form) return;

		const original = form.dataset.labelSubmit ?? btn.innerText;
		const submitting = form.dataset.labelSubmitting ?? "LOGGING...";
		const success = form.dataset.labelSuccess ?? "SUCCESS // LOGGED";

		btn.innerText = submitting;
		btn.classList.add("animate-pulse");

		setTimeout(() => {
			btn.innerText = success;
			btn.classList.remove("animate-pulse");
			btn.classList.add("bg-green-500", "text-black");
			form.reset();

			setTimeout(() => {
				btn.innerText = original;
				btn.classList.remove("bg-green-500", "text-black");
			}, 3000);
		}, 1500);
	});
</script>
