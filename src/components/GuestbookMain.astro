---
import Flame from "@lucide/astro/icons/flame";
import data from "../assets/data.json";

const gb = data.guestbook;
---

<main class="overflow-x-hidden pt-24 pb-16 sm:pt-28 sm:pb-20 lg:pt-32 lg:pb-24">
	<section class="container mx-auto mb-16 px-4 sm:mb-20 sm:px-6 lg:mb-24">
		<div
			class="flex flex-col items-stretch gap-4 sm:flex-row sm:items-end sm:justify-between lg:gap-6"
		>
			<h1
				class="mb-0 w-full max-w-full wrap-break-word font-display text-[clamp(2.75rem,12vw,7.25rem)] leading-[0.95] sm:leading-none lg:w-auto lg:max-w-none"
			>
				{gb.header.titleLine} <br />
				<span class="inline-block bg-accent px-2 py-1 text-black sm:inline sm:px-4 sm:py-0"
					>{gb.header.titleHighlight}</span
				>
			</h1>
			<div
				class="shrink-0 self-start bg-black px-4 py-2 text-base font-bold text-white brutalist-border sm:self-end sm:px-6 sm:text-xl dark:bg-white dark:text-black"
			>
				{gb.header.version}
			</div>
		</div>
		<p
			class="mt-6 max-w-2xl border-l-4 border-black pl-4 text-lg font-bold sm:mt-8 sm:border-l-8 sm:pl-6 sm:text-xl dark:border-white lg:text-2xl"
		>
			{gb.intro.lines.map((line, i) => (
				<>
					{i > 0 && <br />}
					{line}
				</>
			))}
		</p>
	</section>

	<div
		class="container mx-auto grid grid-cols-1 gap-8 px-4 sm:gap-10 sm:px-6 lg:grid-cols-12 lg:gap-12"
	>
		<aside class="min-w-0 lg:col-span-5">
			<div class="lg:sticky lg:top-28 xl:top-32">
				<div class="bg-white p-4 brutalist-border brutalist-shadow sm:p-6 lg:p-8 dark:bg-zinc-900">
					<h2 class="mb-6 font-display text-3xl sm:mb-8 sm:text-4xl">{gb.form.title}</h2>
					<form
						id="guestbook-form"
						class="space-y-6"
						data-label-submit={gb.form.submitLabel}
						data-label-submitting={gb.form.submittingLabel}
						data-label-success={gb.form.successLabel}
					>
						<div class="space-y-2">
							<label class="font-display text-base sm:text-lg">{gb.form.name.label}</label>
							<input
								type="text"
								name={gb.form.name.name}
								placeholder={gb.form.name.placeholder}
								required
								class="w-full border-4 border-black bg-transparent p-4 text-base transition-all outline-none placeholder:opacity-30 focus:bg-accent focus:text-black sm:p-6 dark:border-white"
							/>
						</div>
						<div class="space-y-2">
							<label class="font-display text-base sm:text-lg">{gb.form.email.label}</label>
							<input
								type="email"
								name={gb.form.email.name}
								placeholder={gb.form.email.placeholder}
								class="w-full border-4 border-black bg-transparent p-4 text-base transition-all outline-none placeholder:opacity-30 focus:bg-accent focus:text-black sm:p-6 dark:border-white"
							/>
						</div>
						<div class="space-y-2">
							<label class="font-display text-base sm:text-lg">{gb.form.message.label}</label>
							<textarea
								name={gb.form.message.name}
								rows={gb.form.message.rows}
								placeholder={gb.form.message.placeholder}
								required
								class="w-full resize-none border-4 border-black bg-transparent p-4 text-base transition-all outline-none placeholder:opacity-30 focus:bg-accent focus:text-black sm:p-6 dark:border-white"
							></textarea>
						</div>
						<button
							type="submit"
							id="btn-submit-guestbook"
							class="glitch w-full bg-black py-4 font-display text-xl text-white transition-all brutalist-border hover:bg-accent hover:text-black sm:py-5 sm:text-2xl lg:py-6 lg:text-3xl dark:bg-white dark:text-black dark:hover:bg-accent dark:hover:text-black"
						>
							{gb.form.submitLabel}
						</button>
					</form>
				</div>

				<div
					class="mt-6 rotate-1 bg-accent p-4 text-black brutalist-border sm:mt-8 sm:rotate-2 sm:p-6"
				>
					<p class="text-sm font-bold tracking-tighter uppercase sm:text-base md:text-lg">
						{gb.note}
					</p>
				</div>
			</div>
		</aside>

		<section class="min-w-0 lg:col-span-7">
			<div
				class="mb-8 flex flex-col gap-3 sm:mb-10 sm:flex-row sm:items-end sm:justify-between sm:gap-4 lg:mb-12"
			>
				<h2 class="wrap-break-word font-display text-3xl sm:text-4xl lg:text-5xl">
					{gb.list.title}
				</h2>
				<div class="shrink-0 text-sm font-bold sm:text-base">{gb.list.entriesBadge}</div>
			</div>

			<div id="message-list" class="grid grid-cols-1 gap-8 sm:gap-10 lg:gap-12">
				{
					gb.entries.map((entry) => (
						<div class:list={[entry.cardClass, "min-w-0"]}>
							<div
								class="mb-4 flex min-w-0 flex-wrap items-start justify-between gap-x-3 gap-y-2 sm:mb-6"
							>
								<div
									class:list={[
										entry.badgeClass,
										"max-w-[min(100%,12rem)] shrink-0 truncate sm:max-w-none sm:overflow-visible sm:whitespace-normal sm:text-clip",
									]}
								>
									{entry.id}
								</div>
								<span
									class="max-w-full min-w-0 shrink text-right text-xs font-bold wrap-break-word opacity-60 sm:text-sm"
									>{entry.datetime}</span
								>
							</div>
							<h3 class="mb-3 wrap-break-word font-display text-2xl sm:mb-4 sm:text-3xl">
								{entry.author}
							</h3>
							<p class:list={[entry.messageClass, "wrap-break-word"]}>{entry.message}</p>
							{entry.showFlame ? (
								<div class="absolute -right-2 -bottom-2 hidden bg-white p-1.5 brutalist-border group-hover:block sm:-right-4 sm:-bottom-4 sm:p-2 dark:bg-zinc-800">
									<Flame class="size-6 stroke-[1.5] text-red-500 sm:size-8" aria-hidden="true" />
								</div>
							) : null}
						</div>
					))
				}
			</div>

			<button
				type="button"
				id="btn-load-more"
				class="mt-10 w-full bg-black p-5 font-display text-lg text-white transition-all brutalist-border hover:bg-accent hover:text-black sm:mt-12 sm:p-6 md:mt-16 md:p-8 md:text-2xl dark:bg-white dark:text-black dark:hover:bg-accent dark:hover:text-black"
			>
				{gb.list.loadMoreLabel}
			</button>
		</section>
	</div>
</main>

<script is:inline>
	const form = document.getElementById("guestbook-form");
	const btn = document.getElementById("btn-submit-guestbook");
	form?.addEventListener("submit", (e) => {
		e.preventDefault();
		if (!btn || !form) return;

		const original = form.dataset.labelSubmit ?? btn.innerText;
		const submitting = form.dataset.labelSubmitting ?? "LOGGING...";
		const success = form.dataset.labelSuccess ?? "SUCCESS // LOGGED";

		btn.innerText = submitting;
		btn.classList.add("animate-pulse");

		setTimeout(() => {
			btn.innerText = success;
			btn.classList.remove("animate-pulse");
			btn.classList.add("bg-green-500", "text-black");
			form.reset();

			setTimeout(() => {
				btn.innerText = original;
				btn.classList.remove("bg-green-500", "text-black");
			}, 3000);
		}, 1500);
	});
</script>
