---
import Flame from "@lucide/astro/icons/flame";
---

<main class="pt-32 pb-24">
	<section class="container mx-auto mb-24 px-6">
		<div class="flex flex-col items-end gap-4 lg:flex-row">
			<h1 class="mb-0 font-display text-[10vw] leading-none">
				GUEST <br />
				<span class="bg-accent px-4 text-black">BOOK</span>
			</h1>
			<div
				class="mb-4 bg-black px-6 py-2 font-bold text-xl text-white brutalist-border lg:mb-8 dark:bg-white dark:text-black"
			>
				v2.4.0
			</div>
		</div>
		<p
			class="mt-8 max-w-2xl border-l-8 border-black pl-6 text-2xl font-bold dark:border-white"
		>
			SAY SOMETHING. LEAVE A TRACE. <br />
			VANDALISM IS WELCOME HERE.
		</p>
	</section>

	<div class="container mx-auto grid grid-cols-1 gap-12 px-6 lg:grid-cols-12">
		<aside class="lg:col-span-5">
			<div class="sticky top-32">
				<div class="bg-white p-8 brutalist-border brutalist-shadow dark:bg-zinc-900">
					<h2 class="mb-8 font-display text-4xl">SIGN THE BOOK</h2>
					<form id="guestbook-form" class="space-y-6">
						<div class="space-y-2">
							<label class="font-display text-lg">WHO ARE YOU?</label>
							<input
								type="text"
								name="name"
								placeholder="ANONYMOUS_USER"
								required
								class="w-full border-4 border-black bg-transparent p-6 transition-all outline-none placeholder:opacity-30 focus:bg-accent focus:text-black dark:border-white"
							/>
						</div>
						<div class="space-y-2">
							<label class="font-display text-lg">EMAIL (OPTIONAL)</label>
							<input
								type="email"
								name="email"
								placeholder="GHOST@PROTO.COL"
								class="w-full border-4 border-black bg-transparent p-6 transition-all outline-none placeholder:opacity-30 focus:bg-accent focus:text-black dark:border-white"
							/>
						</div>
						<div class="space-y-2">
							<label class="font-display text-lg">YOUR MANIFESTO</label>
							<textarea
								name="message"
								rows="5"
								placeholder="TYPE YOUR MESSAGE HERE..."
								required
								class="w-full resize-none border-4 border-black bg-transparent p-6 transition-all outline-none placeholder:opacity-30 focus:bg-accent focus:text-black dark:border-white"
							></textarea>
						</div>
						<button
							type="submit"
							id="btn-submit-guestbook"
							class="glitch w-full bg-black py-6 font-display text-3xl text-white transition-all brutalist-border hover:bg-accent hover:text-black dark:bg-white dark:text-black dark:hover:bg-accent dark:hover:text-black"
						>
							SUBMIT LOG
						</button>
					</form>
				</div>

				<div class="mt-8 rotate-2 bg-accent p-6 text-black brutalist-border">
					<p class="text-lg font-bold tracking-tighter uppercase">
						NOTE: MESSAGES ARE PUBLIC. DON'T BE A COWARD.
					</p>
				</div>
			</div>
		</aside>

		<section class="lg:col-span-7">
			<div class="mb-12 flex items-center justify-between">
				<h2 class="font-display text-5xl">LOGGED_ENTRY</h2>
				<div class="font-bold">[ 24 ENTRIES ]</div>
			</div>

			<div id="message-list" class="grid grid-cols-1 gap-12">
				<div
					class="group relative bg-white p-8 brutalist-border brutalist-entry-card dark:bg-zinc-900"
				>
					<div class="mb-6 flex items-start justify-between">
						<div
							class="bg-black px-4 py-1 font-bold text-white dark:bg-accent dark:text-black"
						>
							0x0F4
						</div>
						<span class="text-sm font-bold opacity-60">2024-05-12 // 14:20</span>
					</div>
					<h3 class="mb-4 font-display text-3xl">CYBER_VANDAL</h3>
					<p class="text-xl leading-relaxed">
						LOVE THE BRUTALIST VIBE. IT'S RAW, IT'S UNFILTERED. KEEP BREAKING THE WEB.
					</p>
					<div
						class="absolute -right-4 -bottom-4 hidden bg-white p-2 brutalist-border group-hover:block dark:bg-zinc-800"
					>
						<Flame class="size-8 stroke-[1.5] text-red-500" aria-hidden="true" />
					</div>
				</div>

				<div
					class="group relative -rotate-1 bg-black p-8 text-white brutalist-border brutalist-entry-card dark:bg-white dark:text-black"
				>
					<div class="mb-6 flex items-start justify-between">
						<div class="bg-accent px-4 py-1 font-bold text-black">0x0F3</div>
						<span class="text-sm font-bold opacity-60">2024-05-11 // 09:45</span>
					</div>
					<h3 class="mb-4 font-display text-3xl">SARAH_D</h3>
					<p class="text-xl leading-relaxed">
						FINALLY A PORTFOLIO THAT DOESN'T LOOK LIKE A NOTION PAGE. REFRESHING.
					</p>
				</div>

				<div
					class="group relative rotate-1 bg-accent p-8 text-black brutalist-border brutalist-entry-card"
				>
					<div class="mb-6 flex items-start justify-between">
						<div class="bg-black px-4 py-1 font-bold text-white">0x0F2</div>
						<span class="text-sm font-bold opacity-60">2024-05-10 // 22:12</span>
					</div>
					<h3 class="mb-4 font-display text-3xl">KODER_X</h3>
					<p
						class="text-xl leading-relaxed font-bold italic underline decoration-4"
					>
						GLITCH IN THE MATRIX FOUND. I'M STAYING HERE FOREVER.
					</p>
				</div>

				<div
					class="group relative bg-white p-8 brutalist-border brutalist-entry-card dark:bg-zinc-900"
				>
					<div class="mb-6 flex items-start justify-between">
						<div
							class="bg-black px-4 py-1 font-bold text-white dark:bg-accent dark:text-black"
						>
							0x0F1
						</div>
						<span class="text-sm font-bold opacity-60">2024-05-08 // 11:30</span>
					</div>
					<h3 class="mb-4 font-display text-3xl">ANON_99</h3>
					<p class="text-xl leading-relaxed">
						JUST DROPPING BY TO SAY HI. THE DESIGN IS AGGRESSIVE BUT I LIKE IT.
					</p>
				</div>
			</div>

			<button
				type="button"
				id="btn-load-more"
				class="mt-16 w-full bg-black p-8 font-display text-2xl text-white transition-all brutalist-border hover:bg-accent hover:text-black dark:bg-white dark:text-black dark:hover:bg-accent dark:hover:text-black"
			>
				LOAD_ANOTHER_PAGE
			</button>
		</section>
	</div>
</main>

<script is:inline>
	const form = document.getElementById("guestbook-form");
	form?.addEventListener("submit", (e) => {
		e.preventDefault();
		const btn = document.getElementById("btn-submit-guestbook");
		if (!btn) return;
		const originalText = btn.innerText;

		btn.innerText = "LOGGING...";
		btn.classList.add("animate-pulse");

		setTimeout(() => {
			btn.innerText = "SUCCESS // LOGGED";
			btn.classList.remove("animate-pulse");
			btn.classList.add("bg-green-500", "text-black");
			form.reset();

			setTimeout(() => {
				btn.innerText = originalText;
				btn.classList.remove("bg-green-500", "text-black");
			}, 3000);
		}, 1500);
	});
</script>
