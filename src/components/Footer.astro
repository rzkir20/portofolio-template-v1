---
import data from "../assets/data.json";

const year = new Date().getFullYear();
const { brand, links, tagline } = data.footer;
---

<footer
  class="border-t-4 border-black bg-white py-8 dark:border-white dark:bg-black sm:border-t-8 sm:py-12"
>
  <div
    class="container mx-auto flex flex-col items-center justify-between gap-8 px-4 sm:gap-10 sm:px-6 md:flex-row md:gap-12"
  >
    <div
      class="text-center font-display text-2xl sm:text-3xl md:text-left md:text-4xl"
    >
      {brand}
      <span class="text-accent">{year}</span>
    </div>

    <div
      class="flex max-w-full flex-wrap justify-center gap-x-6 gap-y-3 font-display text-lg sm:gap-8 sm:text-xl md:text-2xl"
    >
      {
        links.map((link) => (
          <a
            href={link.href}
            target="_blank"
            id={link.id}
            class="underline hover:text-accent"
          >
            {link.label}
          </a>
        ))
      }
    </div>

    <div
      class="max-w-md text-center text-sm font-bold sm:text-base md:max-w-none md:text-right"
    >
      {
        tagline.lines.map((line, i) => (
          <>
            {i > 0 && <br />}
            {line}
          </>
        ))
      }
    </div>
  </div>
</footer>
